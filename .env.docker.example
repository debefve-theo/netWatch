# App
APP_URL="http://speedtest.squal.cloud:8080"
APP_PORT="8080"
NEXT_PUBLIC_APP_NAME="NetWatch"
PORT="3000"
HOSTNAME="0.0.0.0"

# Postgres container wiring
POSTGRES_DB="speedtest_db"
POSTGRES_USER="speedtest"
POSTGRES_PASSWORD="change-me"
DATABASE_URL="postgresql://speedtest:change-me@postgres:5432/speedtest_db?schema=public"

# Security
API_KEY_PEPPER="generate-with-openssl-rand-hex-32"
DASHBOARD_PASSWORD="change-me"
SESSION_SECRET="generate-with-openssl-rand-hex-32"
DEVICE_OFFLINE_THRESHOLD_MINUTES="10"
ALERT_MIN_DOWNLOAD_MBPS="50"
ALERT_MIN_UPLOAD_MBPS="3"
ALERT_COOLDOWN_MINUTES="30"
TELEGRAM_BOT_TOKEN=""
TELEGRAM_CHAT_ID=""

# Optional seed defaults
SEED_DEVICE_NAME="Raspberry Pi"
SEED_DEVICE_LOCATION=""

# Container behavior
RUN_DB_MIGRATIONS="true"
