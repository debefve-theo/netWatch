# Application
APP_URL="https://speedtest.squal.cloud"
NEXT_PUBLIC_APP_NAME="NetWatch"
PORT="3000"
HOSTNAME="0.0.0.0"

# PostgreSQL
# Local host example. For Docker Compose, use .env.docker.example instead.
DATABASE_URL="postgresql://speedtest:change-me@localhost:5432/speedtest_db?schema=public"

# Security
API_KEY_PEPPER="generate-with-openssl-rand-hex-32"

# Dashboard password protection (leave unset to disable auth in dev)
DASHBOARD_PASSWORD="change-me"
SESSION_SECRET="generate-with-openssl-rand-hex-32"
DEVICE_OFFLINE_THRESHOLD_MINUTES="10"
ALERT_MIN_DOWNLOAD_MBPS="50"
ALERT_MIN_UPLOAD_MBPS="3"
ALERT_COOLDOWN_MINUTES="30"
TELEGRAM_BOT_TOKEN=""
TELEGRAM_CHAT_ID=""

# Optional seed defaults
SEED_DEVICE_NAME="Raspberry Pi"
SEED_DEVICE_LOCATION=""
